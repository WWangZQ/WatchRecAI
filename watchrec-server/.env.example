# WatchRec 电脑端环境变量
APP_TOKEN=CHANGE_ME
# CA 证书路径（默认项目根目录下的 server.crt）
# CA_CERT=server.crt
# LAN IP 手动指定（留空 = 自动探测，Clash TUN 下可能返回假 IP 198.18.x.x）
# LAN_IP_OVERRIDE=192.168.1.100

# ── AI 整理（OpenAI 兼容在线 API）──
# 填了才会生成「全文」(去噪) 和「AI 总结」；留空则只做转写。
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-xxxx
# LLM_MODEL=gpt-4o-mini
